# ─── App ──────────────────────────────────────────────
APP_NAME=Invoxio Agent
APP_ENV=development
APP_PORT=8000

# ─── Google GenAI (Gemini) ────────────────────────────
GOOGLE_GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE

# Gemini model options:
# gemini-1.5-flash     → free tier, fast
# gemini-1.5-pro       → smarter, paid
# gemini-2.0-flash-exp → latest experimental
GEMINI_MODEL=gemini-1.5-flash

# ─── MongoDB ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/invoxio

# ─── LangSmith Tracing (Optional) ────────────────────
# Get key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=invoxio-agent

# ─── Agent Settings ───────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0
